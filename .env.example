# -----------------------------------------------------------------------------
# TCP — TikTok Creativity Program
# -----------------------------------------------------------------------------

# App
NEXT_PUBLIC_SITE_URL=https://tiktokcreativityprogram.com

# Supabase (email captures, etc.)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (newsletter)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Analytics
# Google Analytics 4 — only fires in production when set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Plausible — secondary analytics, production only.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tiktokcreativityprogram.com
# PostHog — product analytics. Set both to activate.
# Get a project API key from PostHog dashboard → Project Settings.
# Use the US cloud host unless you're on EU.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Search Console verification (optional)
NEXT_PUBLIC_SEARCH_CONSOLE_VERIFICATION=
